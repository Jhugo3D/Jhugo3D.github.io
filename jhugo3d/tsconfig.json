{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "strictNullChecks": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "jsx": "preserve",
    "lib": ["DOM", "ES2020"]
  },
  "include": ["src", "astro.config.mjs", "src/**/*.ts", "src/**/*.tsx", "src/**/*.astro"]
}
