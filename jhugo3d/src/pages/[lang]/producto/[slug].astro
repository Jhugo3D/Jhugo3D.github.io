---
import Layout from '../../../components/Layout.astro';
import ProductCard from '../../../components/ProductCard.astro';
import { getCollection, getEntry } from 'astro:content';
import { t, type Lang } from '../../../i18n/ui';

export async function getStaticPaths() {
  const productos = await getCollection('productos');
  const langs: Lang[] = ['ca', 'en'];
  return langs.flatMap(lang =>
    productos.map(p => ({ params: { lang, slug: p.slug } }))
  );
}

const { lang, slug } = Astro.params as { lang: Lang; slug: string };
const prefix = `/${lang}`;

const producto = await getEntry('productos', slug!);
if (!producto) return Astro.redirect('/404');

const { nombre, precio, precioTexto, precioVariante, categoria, imagen, descripcion } = producto.data;
const { Content } = await producto.render();

const catLabels: Record<string, Record<string, string>> = {
  ca: { joyeria: 'Joieria', soportes: 'Suports', figuras: 'Figures', marcos: 'Marcs', decoracion: 'Decoració' },
  en: { joyeria: 'Jewellery', soportes: 'Holders', figuras: 'Figures', marcos: 'Frames', decoracion: 'Decor' },
};
const cl = catLabels[lang] ?? catLabels['en'];

const todos = await getCollection('productos');
const relacionados = todos
  .filter(p => p.data.categoria === categoria && p.slug !== slug)
  .slice(0, 3);
---

<Layout
  title={nombre}
  description={descripcion ?? `${nombre} — ${precioTexto}. Pieza impresa en 3D disponible en Jhugo3D.`}
  ogImage={imagen}
>
  <div class="prod-back">
    <div class="container">
      <a href={`${prefix}/catalogo`} class="back-link">{t(lang, 'prod.volver')}</a>
    </div>
  </div>

  <section class="prod-section">
    <div class="container prod-layout">
      <div class="prod-img-wrap">
        <img src={imagen} alt={nombre} width="600" height="600" loading="eager" decoding="async" class="prod-img" />
      </div>

      <div class="prod-info">
        <span class="badge">{cl[categoria] ?? categoria}</span>
        <h1 class="prod-name">{nombre}</h1>
        <div class="prod-price">
          <span class="price-big">{precioTexto}</span>
          {precioVariante && <span class="price-var">{precioVariante}</span>}
        </div>

        {descripcion && (
          <div class="prod-desc"><Content /></div>
        )}

        <div class="prod-nota">
          <label for="prodNota" class="nota-label">
            {t(lang, 'prod.notaLabel')} <span class="nota-opt">{t(lang, 'prod.notaOpt')}</span>
          </label>
          <textarea id="prodNota" class="nota-textarea" placeholder={t(lang, 'prod.notaPlaceholder')} rows="3"></textarea>
        </div>

        <div class="prod-actions">
          <button class="btn btn-primary btn-lg jh-add-btn" data-slug={slug} data-nombre={nombre} data-precio={precio} data-preciotexto={precioTexto} data-imagen={imagen}>
            {t(lang, 'prod.anadir')}
          </button>
          <a href={`${prefix}/personalizado`} class="btn btn-outline">{t(lang, 'prod.personalizado')}</a>
        </div>

        <div class="prod-meta">
          <div class="meta-row">
            <span class="meta-key">{t(lang, 'prod.contacto')}</span>
            <span class="meta-val">soportejhugo3d@gmail.com</span>
          </div>
          <div class="meta-row">
            <span class="meta-key">{t(lang, 'prod.categoria')}</span>
            <span class="meta-val">{cl[categoria] ?? categoria}</span>
          </div>
          <div class="meta-row">
            <span class="meta-key">{t(lang, 'prod.plazo')}</span>
            <span class="meta-val">{t(lang, 'prod.plazoVal')}</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  {relacionados.length > 0 && (
    <section class="section">
      <div class="container">
        <h2 class="section-title" style="font-size: 1.5rem; margin-bottom: 1.5rem;">{t(lang, 'prod.relacionados')}</h2>
        <div class="product-grid" style="grid-template-columns: repeat(3, 1fr);">
          {relacionados.map(p => (
            <ProductCard
              slug={p.slug}
              nombre={p.data.nombre}
              precio={p.data.precio}
              precioTexto={p.data.precioTexto}
              precioVariante={p.data.precioVariante}
              categoria={p.data.categoria}
              imagen={p.data.imagen}
              lang={lang}
              prodPrefix={`${prefix}/producto`}
            />
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>

<style>
.prod-back { padding-top: calc(64px + 1.5rem); padding-bottom: 1rem; }
.back-link { font-size: 0.875rem; color: var(--text-muted); transition: color 0.15s; }
.back-link:hover { color: var(--gold); }
.prod-section { padding-bottom: 5rem; }
.prod-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; }
.prod-img-wrap { position: sticky; top: calc(64px + 1.5rem); background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); overflow: hidden; aspect-ratio: 1; }
.prod-img { width: 100%; height: 100%; object-fit: cover; }
.prod-info { display: flex; flex-direction: column; gap: 1.5rem; }
.prod-name { font-size: clamp(1.5rem, 4vw, 2.25rem); line-height: 1.15; }
.prod-price { display: flex; align-items: baseline; gap: 0.5rem; }
.price-big { font-family: var(--font-display); font-size: 2.5rem; font-weight: 700; color: var(--gold); }
.price-var { color: var(--text-muted); }
.prod-desc { color: var(--text-muted); line-height: 1.7; font-size: 0.95rem; border-top: 1px solid var(--border); padding-top: 1.5rem; }
.prod-nota { display: flex; flex-direction: column; gap: 0.5rem; border-top: 1px solid var(--border); padding-top: 1.5rem; }
.nota-label { font-family: var(--font-display); font-size: 0.8rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text-subtle); }
.nota-opt { font-weight: 400; text-transform: none; letter-spacing: 0; opacity: 0.7; }
.nota-textarea { width: 100%; padding: 0.85rem 1rem; background: var(--surface); border: 1px solid var(--border-2); border-radius: var(--radius); color: var(--text); font-family: var(--font-body); font-size: 0.9rem; line-height: 1.6; resize: vertical; outline: none; transition: border-color 0.15s; min-height: 80px; }
.nota-textarea:focus { border-color: var(--gold); }
.nota-textarea::placeholder { color: var(--text-subtle); }
.prod-actions { display: flex; flex-direction: column; gap: 0.75rem; }
.btn-lg { padding: 1rem 2rem; font-size: 1rem; }
.prod-meta { display: flex; flex-direction: column; gap: 0.6rem; border-top: 1px solid var(--border); padding-top: 1.5rem; }
.meta-row { display: flex; justify-content: space-between; font-size: 0.875rem; }
.meta-key { color: var(--text-subtle); }
.meta-val { color: var(--text-muted); }
@media (max-width: 760px) { .prod-layout { grid-template-columns: 1fr; gap: 2rem; } .prod-img-wrap { position: static; } .product-grid { grid-template-columns: 1fr !important; } }
</style>