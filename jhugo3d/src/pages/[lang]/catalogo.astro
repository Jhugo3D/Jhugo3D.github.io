---
import Layout from '../../components/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { getCollection } from 'astro:content';
import { t, type Lang } from '../../i18n/ui';

export function getStaticPaths() {
  return [{ params: { lang: 'ca' } }, { params: { lang: 'en' } }];
}

const { lang } = Astro.params as { lang: Lang };
const prefix = `/${lang}`;

const todos = await getCollection('productos');
const total = todos.length;

const catLabels: Record<string, Record<string, string>> = {
  ca: { todos: 'Tots', joyeria: 'Joieria', soportes: 'Suports', figuras: 'Figures', marcos: 'Marcs', decoracion: 'Decoració' },
  en: { todos: 'All', joyeria: 'Jewellery', soportes: 'Holders', figuras: 'Figures', marcos: 'Frames', decoracion: 'Decor' },
};
const cl = catLabels[lang] ?? catLabels['en'];

const rangos = [
  { key: 'todos', label: lang === 'en' ? 'All prices' : 'Tots els preus' },
  { key: '0-6',   label: '3€ – 6€' },
  { key: '7-15',  label: '7€ – 15€' },
  { key: '16-99', label: '20€ – 30€' },
];

const descriptions: Record<string, string> = {
  ca: '48 dissenys disponibles des de 3€.',
  en: '48 designs available from €3.',
};
---

<Layout title={t(lang, 'nav.catalogo')} description={descriptions[lang]}>
  <section class="cat-hero">
    <div class="container">
      <p class="eyebrow">{t(lang, 'cat.eyebrow')}</p>
      <h1>{t(lang, 'cat.heading')} <span class="text-gold">({total})</span></h1>
      <p class="cat-sub">{total} {t(lang, 'cat.sub')}</p>
    </div>
  </section>

  <section class="section" style="padding-top: 2rem;">
    <div class="container">
      <div class="filters">
        <div class="filter-group">
          <span class="filter-label">{lang === 'en' ? 'Category' : 'Categoria'}</span>
          <div class="filter-btns" id="cat-filter">
            {['todos','joyeria','soportes','figuras','marcos','decoracion'].map(key => (
              <button class:list={['filter-btn', { active: key === 'todos' }]} data-filter="cat" data-value={key}>
                {cl[key]}
              </button>
            ))}
          </div>
        </div>
        <div class="filter-group">
          <span class="filter-label">{t(lang, 'cat.precio')}</span>
          <div class="filter-btns" id="price-filter">
            {rangos.map(r => (
              <button class:list={['filter-btn', { active: r.key === 'todos' }]} data-filter="price" data-value={r.key}>
                {r.label}
              </button>
            ))}
          </div>
        </div>
      </div>

      <div class="product-grid" id="product-grid">
        {todos.map((p, i) => (
          <div class="product-item" data-cat={p.data.categoria} data-precio={p.data.precio}>
            <ProductCard
              slug={p.slug}
              nombre={p.data.nombre}
              precio={p.data.precio}
              precioTexto={p.data.precioTexto}
              precioVariante={p.data.precioVariante}
              categoria={p.data.categoria}
              imagen={p.data.imagen}
              destacado={p.data.destacado}
              lazy={i > 7}
              lang={lang}
              prodPrefix={`${prefix}/producto`}
            />
          </div>
        ))}
      </div>

      <p class="empty-msg" id="empty-msg" hidden>
        {t(lang, 'cat.empty')} <button class="btn btn-ghost" id="reset-filters">{t(lang, 'cat.reset')}</button>
      </p>
    </div>
  </section>
</Layout>

<style>
.cat-hero { padding-top: calc(64px + 3.5rem); padding-bottom: 2.5rem; border-bottom: 1px solid var(--border); }
.cat-hero h1 { font-size: clamp(2rem, 6vw, 3.5rem); margin-top: 0.5rem; }
.cat-sub { color: var(--text-muted); margin-top: 0.5rem; }
.filters { display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 2.5rem; padding: 1.25rem; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); }
.filter-group { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }
.filter-label { font-family: var(--font-display); font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-subtle); min-width: 72px; flex-shrink: 0; }
.filter-btns { display: flex; gap: 0.4rem; flex-wrap: wrap; }
.filter-btn { padding: 0.35rem 0.85rem; font-family: var(--font-display); font-size: 0.8rem; font-weight: 500; border: 1.5px solid var(--border); border-radius: 100px; color: var(--text-muted); background: transparent; cursor: pointer; transition: all 0.15s; }
.filter-btn:hover { border-color: var(--text-muted); color: var(--text); }
.filter-btn.active { border-color: var(--gold); color: var(--gold); background: rgba(212,168,50,0.08); }
.product-item { display: contents; }
.product-item.hidden { display: none; }
.empty-msg { text-align: center; color: var(--text-muted); padding: 4rem 0; font-size: 1rem; grid-column: 1 / -1; }
@media (max-width: 600px) { .filter-group { flex-direction: column; align-items: flex-start; } .filter-label { min-width: unset; } }
</style>

<script>
const grid = document.getElementById('product-grid')!;
const emptyMsg = document.getElementById('empty-msg')!;
const items = Array.from(grid.querySelectorAll<HTMLElement>('.product-item'));
let activeCat = 'todos', activePrice = 'todos';
function inPrice(price: number, range: string) { if (range === 'todos') return true; const [min, max] = range.split('-').map(Number); return price >= min && price <= max; }
function applyFilters() { let v = 0; items.forEach(item => { const show = (activeCat === 'todos' || item.dataset.cat === activeCat) && inPrice(Number(item.dataset.precio), activePrice); item.classList.toggle('hidden', !show); if (show) v++; }); emptyMsg.hidden = v > 0; }
document.querySelectorAll<HTMLButtonElement>('.filter-btn').forEach(btn => { btn.addEventListener('click', () => { btn.closest('.filter-btns')!.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active')); btn.classList.add('active'); if (btn.dataset.filter === 'cat') activeCat = btn.dataset.value!; if (btn.dataset.filter === 'price') activePrice = btn.dataset.value!; applyFilters(); }); });
document.getElementById('reset-filters')?.addEventListener('click', () => { activeCat = activePrice = 'todos'; document.querySelectorAll('.filter-btn').forEach(b => { b.classList.toggle('active', b.dataset.value === 'todos'); }); applyFilters(); });
</script>