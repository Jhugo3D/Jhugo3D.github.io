---
import Layout from '../components/Layout.astro';
---

<Layout title="Página no encontrada" description="Esta página no existe. Vuelve al catálogo de Jhugo3D.">
  <section class="not-found">
    <div class="container">
      <div class="nf-inner reveal">
        <span class="nf-num">404</span>
        <h1>Esta pieza no existe.</h1>
        <p>
          Igual la hemos movido, igual aún no la hemos imprimido.<br />
          Pero si tienes una idea, podemos crearla.
        </p>
        <div class="nf-actions">
          <a href="/catalogo" class="btn btn-primary">Ver catálogo →</a>
          <a href="/personalizado" class="btn btn-outline">Pedir personalizado</a>
          <a href="/" class="btn btn-ghost">Inicio</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
.not-found {
  min-height: 100svh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 64px;
}
.nf-inner { text-align: center; max-width: 480px; }

.nf-num {
  display: block;
  font-family: var(--font-display);
  font-size: clamp(5rem, 15vw, 10rem);
  font-weight: 700;
  color: var(--border-2);
  line-height: 1;
  margin-bottom: 0.5rem;
  background: linear-gradient(135deg, var(--brand) 0%, var(--gold) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
h1 {
  font-size: clamp(1.5rem, 4vw, 2rem);
  margin-bottom: 1rem;
}
p {
  color: var(--text-muted);
  line-height: 1.7;
  margin-bottom: 2rem;
}
.nf-actions {
  display: flex;
  gap: 0.75rem;
  justify-content: center;
  flex-wrap: wrap;
}
</style>
