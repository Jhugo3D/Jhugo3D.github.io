---
import Layout from '../components/Layout.astro';
import { getCollection } from 'astro:content';

const productos = await getCollection('productos');
const productosData = productos.map(p => ({
  slug: p.slug,
  nombre: p.data.nombre,
  precio: p.data.precio,
  precioTexto: p.data.precioTexto,
  precioVariante: p.data.precioVariante ?? '',
  categoria: p.data.categoria,
  imagen: p.data.imagen,
  descripcion: p.data.descripcion ?? '',
  destacado: p.data.destacado ?? false,
}));
---

<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin — Jhugo3D</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', system-ui, sans-serif; background: #0a0a0a; color: #f0f0f0; min-height: 100vh; }

    /* LOGIN */
    #login-screen { display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: 2rem; }
    .login-card { background: #151515; border: 1px solid #232323; border-radius: 12px; padding: 2.5rem; width: 100%; max-width: 400px; }
    .login-card h1 { font-size: 1.5rem; font-weight: 700; margin-bottom: 0.4rem; }
    .login-card p { color: #888; font-size: 0.875rem; margin-bottom: 2rem; }
    .field { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1rem; }
    .field label { font-size: 0.8rem; font-weight: 600; color: #aaa; letter-spacing: 0.04em; text-transform: uppercase; }
    .field input { background: #1e1e1e; border: 1.5px solid #2e2e2e; border-radius: 8px; padding: 0.75rem 1rem; color: #f0f0f0; font-size: 0.9rem; outline: none; transition: border-color 0.15s; }
    .field input:focus { border-color: #D4A832; }
    .btn-login { width: 100%; padding: 0.85rem; background: #D4A832; border: none; border-radius: 8px; color: #080808; font-weight: 700; font-size: 0.9rem; cursor: pointer; transition: background 0.15s; margin-top: 0.5rem; }
    .btn-login:hover { background: #F0C040; }
    .login-err { color: #e44; font-size: 0.8rem; margin-top: 0.75rem; text-align: center; display: none; }
    .logo { font-size: 1.1rem; font-weight: 800; color: #D4A832; margin-bottom: 1.5rem; display: block; }

    /* ADMIN PANEL */
    #admin-panel { display: none; }
    .admin-header { background: #151515; border-bottom: 1px solid #232323; padding: 1rem 1.5rem; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 100; }
    .admin-header h1 { font-size: 1rem; font-weight: 700; }
    .admin-header span { font-size: 0.8rem; color: #888; }
    .btn-logout { background: none; border: 1px solid #2e2e2e; border-radius: 6px; color: #888; font-size: 0.78rem; padding: 0.35rem 0.75rem; cursor: pointer; transition: all 0.15s; }
    .btn-logout:hover { border-color: #e44; color: #e44; }

    .admin-content { padding: 1.5rem; max-width: 1100px; margin: 0 auto; }
    .admin-stats { display: flex; gap: 1rem; margin-bottom: 2rem; flex-wrap: wrap; }
    .admin-stat { background: #151515; border: 1px solid #232323; border-radius: 8px; padding: 1rem 1.5rem; }
    .admin-stat .n { font-size: 1.75rem; font-weight: 700; color: #D4A832; }
    .admin-stat .l { font-size: 0.75rem; color: #888; text-transform: uppercase; letter-spacing: 0.06em; margin-top: 0.2rem; }

    .section-title { font-size: 0.8rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #888; margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 1px solid #1e1e1e; }
    
    /* Products table */
    .prod-table { width: 100%; border-collapse: collapse; margin-bottom: 2rem; }
    .prod-table th { text-align: left; font-size: 0.72rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: #555; padding: 0.5rem 0.75rem; border-bottom: 1px solid #232323; }
    .prod-table td { padding: 0.6rem 0.75rem; border-bottom: 1px solid #1a1a1a; font-size: 0.85rem; vertical-align: middle; }
    .prod-table tr:hover td { background: #111; }
    .prod-img { width: 40px; height: 40px; border-radius: 6px; object-fit: cover; background: #1e1e1e; }
    .cat-badge { display: inline-block; padding: 0.15rem 0.5rem; background: #1e1e1e; border: 1px solid #2e2e2e; border-radius: 100px; font-size: 0.7rem; color: #888; }
    .destacado-dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; background: #D4A832; }
    .btn-edit { background: none; border: 1px solid #2e2e2e; border-radius: 6px; color: #aaa; font-size: 0.72rem; padding: 0.3rem 0.65rem; cursor: pointer; transition: all 0.15s; }
    .btn-edit:hover { border-color: #D4A832; color: #D4A832; }

    /* Edit modal */
    .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.75); z-index: 200; display: none; align-items: center; justify-content: center; padding: 1rem; }
    .modal-overlay.open { display: flex; }
    .modal { background: #151515; border: 1px solid #232323; border-radius: 12px; padding: 2rem; width: 100%; max-width: 520px; max-height: 90vh; overflow-y: auto; }
    .modal h2 { font-size: 1.1rem; margin-bottom: 1.5rem; }
    .modal-field { display: flex; flex-direction: column; gap: 0.35rem; margin-bottom: 1rem; }
    .modal-field label { font-size: 0.75rem; font-weight: 600; color: #888; letter-spacing: 0.04em; text-transform: uppercase; }
    .modal-field input, .modal-field textarea, .modal-field select { background: #1e1e1e; border: 1.5px solid #2e2e2e; border-radius: 6px; padding: 0.6rem 0.85rem; color: #f0f0f0; font-size: 0.875rem; outline: none; transition: border-color 0.15s; width: 100%; font-family: inherit; }
    .modal-field input:focus, .modal-field textarea:focus, .modal-field select:focus { border-color: #D4A832; }
    .modal-field textarea { resize: vertical; min-height: 80px; }
    .modal-actions { display: flex; gap: 0.75rem; margin-top: 1.5rem; }
    .btn-wa { flex: 1; padding: 0.75rem; background: #25D366; border: none; border-radius: 8px; color: #fff; font-weight: 700; font-size: 0.875rem; cursor: pointer; transition: background 0.15s; }
    .btn-wa:hover { background: #1ebe57; }
    .btn-cancel { padding: 0.75rem 1.25rem; background: none; border: 1px solid #2e2e2e; border-radius: 8px; color: #888; font-size: 0.875rem; cursor: pointer; transition: all 0.15s; }
    .btn-cancel:hover { border-color: #888; color: #f0f0f0; }

    .checkbox-row { display: flex; align-items: center; gap: 0.5rem; cursor: pointer; }
    .checkbox-row input[type="checkbox"] { accent-color: #D4A832; width: 16px; height: 16px; }
  </style>
</head>
<body>

<!-- LOGIN -->
<div id="login-screen">
  <div class="login-card">
    <span class="logo">Jhugo3D ✦ Admin</span>
    <h1>Panel de administración</h1>
    <p>Acceso restringido al propietario.</p>
    <div class="field">
      <label>Email</label>
      <input type="email" id="adm-email" placeholder="tu@email.com" autocomplete="email" />
    </div>
    <div class="field">
      <label>Contraseña</label>
      <input type="password" id="adm-pass" placeholder="••••••••" autocomplete="current-password" />
    </div>
    <button class="btn-login" id="adm-login-btn">Entrar →</button>
    <p class="login-err" id="adm-err">Email o contraseña incorrectos.</p>
  </div>
</div>

<!-- ADMIN PANEL -->
<div id="admin-panel">
  <div class="admin-header">
    <h1>🛠 Jhugo3D — Panel de administración</h1>
    <div style="display:flex;align-items:center;gap:1rem;">
      <span id="adm-user-label"></span>
      <button class="btn-logout" id="adm-logout">Cerrar sesión</button>
    </div>
  </div>

  <div class="admin-content">
    <div class="admin-stats">
      <div class="admin-stat"><div class="n" id="stat-total">0</div><div class="l">Productos totales</div></div>
      <div class="admin-stat"><div class="n" id="stat-dest">0</div><div class="l">Destacados</div></div>
      <div class="admin-stat"><div class="n" id="stat-minprice">—</div><div class="l">Precio mínimo</div></div>
    </div>

    <p class="section-title">Gestión de productos</p>
    <p style="color:#888;font-size:.82rem;margin-bottom:1.25rem;">Haz clic en <strong style="color:#D4A832">Editar</strong> para modificar un producto. Los cambios se envían por WhatsApp al desarrollador para que los aplique.</p>

    <table class="prod-table">
      <thead>
        <tr>
          <th></th>
          <th>Slug</th>
          <th>Nombre</th>
          <th>Precio</th>
          <th>Categoría</th>
          <th>Dest.</th>
          <th></th>
        </tr>
      </thead>
      <tbody id="prod-tbody"></tbody>
    </table>
  </div>
</div>

<!-- EDIT MODAL -->
<div class="modal-overlay" id="edit-modal">
  <div class="modal">
    <h2>Editar producto — <span id="modal-slug"></span></h2>
    <div class="modal-field">
      <label>Nombre</label>
      <input type="text" id="ed-nombre" />
    </div>
    <div class="modal-field">
      <label>Precio (€)</label>
      <input type="number" id="ed-precio" min="0" step="0.5" />
    </div>
    <div class="modal-field">
      <label>Precio visible (ej: "5€" o "Desde 8€")</label>
      <input type="text" id="ed-preciotexto" />
    </div>
    <div class="modal-field">
      <label>Precio variante (opcional, ej: "· desde 12€ personalizado")</label>
      <input type="text" id="ed-preciovariante" />
    </div>
    <div class="modal-field">
      <label>Categoría</label>
      <select id="ed-categoria">
        <option value="joyeria">Joyería</option>
        <option value="soportes">Soportes</option>
        <option value="figuras">Figuras</option>
        <option value="marcos">Marcos</option>
        <option value="decoracion">Decoración</option>
      </select>
    </div>
    <div class="modal-field">
      <label>Descripción</label>
      <textarea id="ed-desc" rows="4"></textarea>
    </div>
    <div class="modal-field">
      <label class="checkbox-row">
        <input type="checkbox" id="ed-destacado" />
        Producto destacado (aparece en el inicio)
      </label>
    </div>
    <div class="modal-actions">
      <button class="btn-cancel" id="modal-cancel">Cancelar</button>
      <button class="btn-wa" id="modal-send">📲 Enviar cambios por WhatsApp</button>
    </div>
  </div>
</div>

<script is:inline define:vars={{ productosData }}>
  var PRODUCTS = productosData;
  var WA = '34630481639';
  var CRED = { email: 'soportejhugo3d@gmail.com', pass: 'Quim guapo' };
  var currentSlug = null;

  /* AUTH */
  function checkSession() {
    return sessionStorage.getItem('jh_admin') === '1';
  }
  function showPanel() {
    document.getElementById('login-screen').style.display = 'none';
    document.getElementById('admin-panel').style.display = 'block';
    document.getElementById('adm-user-label').textContent = CRED.email;
    renderTable();
  }
  if (checkSession()) showPanel();

  document.getElementById('adm-login-btn').addEventListener('click', tryLogin);
  document.getElementById('adm-email').addEventListener('keydown', function(e){ if(e.key==='Enter') tryLogin(); });
  document.getElementById('adm-pass').addEventListener('keydown', function(e){ if(e.key==='Enter') tryLogin(); });

  function tryLogin() {
    var email = document.getElementById('adm-email').value.trim();
    var pass  = document.getElementById('adm-pass').value;
    var err   = document.getElementById('adm-err');
    if (email === CRED.email && pass === CRED.pass) {
      sessionStorage.setItem('jh_admin', '1');
      err.style.display = 'none';
      showPanel();
    } else {
      err.style.display = 'block';
    }
  }

  document.getElementById('adm-logout').addEventListener('click', function() {
    sessionStorage.removeItem('jh_admin');
    location.reload();
  });

  /* TABLE */
  function renderTable() {
    var total = PRODUCTS.length;
    var dest  = PRODUCTS.filter(function(p){ return p.destacado; }).length;
    var prices = PRODUCTS.map(function(p){ return p.precio; });
    document.getElementById('stat-total').textContent   = total;
    document.getElementById('stat-dest').textContent    = dest;
    document.getElementById('stat-minprice').textContent = Math.min.apply(null, prices) + '€';

    var tbody = document.getElementById('prod-tbody');
    tbody.innerHTML = PRODUCTS.map(function(p) {
      return '<tr>' +
        '<td><img class="prod-img" src="' + p.imagen + '" alt="" loading="lazy"></td>' +
        '<td style="color:#555;font-size:.78rem">' + p.slug + '</td>' +
        '<td style="font-weight:600">' + p.nombre + '</td>' +
        '<td style="color:#D4A832;font-weight:700">' + p.precioTexto + '</td>' +
        '<td><span class="cat-badge">' + p.categoria + '</span></td>' +
        '<td>' + (p.destacado ? '<span class="destacado-dot" title="Destacado"></span>' : '') + '</td>' +
        '<td><button class="btn-edit" data-slug="' + p.slug + '">Editar</button></td>' +
      '</tr>';
    }).join('');

    document.querySelectorAll('.btn-edit').forEach(function(btn) {
      btn.addEventListener('click', function() { openModal(btn.dataset.slug); });
    });
  }

  /* MODAL */
  function openModal(slug) {
    var p = PRODUCTS.find(function(x){ return x.slug === slug; });
    if (!p) return;
    currentSlug = slug;
    document.getElementById('modal-slug').textContent    = slug;
    document.getElementById('ed-nombre').value           = p.nombre;
    document.getElementById('ed-precio').value           = p.precio;
    document.getElementById('ed-preciotexto').value      = p.precioTexto;
    document.getElementById('ed-preciovariante').value   = p.precioVariante || '';
    document.getElementById('ed-categoria').value        = p.categoria;
    document.getElementById('ed-desc').value             = p.descripcion;
    document.getElementById('ed-destacado').checked      = p.destacado;
    document.getElementById('edit-modal').classList.add('open');
  }

  document.getElementById('modal-cancel').addEventListener('click', closeModal);
  document.getElementById('edit-modal').addEventListener('click', function(e) {
    if (e.target === this) closeModal();
  });
  function closeModal() {
    document.getElementById('edit-modal').classList.remove('open');
    currentSlug = null;
  }

  document.getElementById('modal-send').addEventListener('click', function() {
    if (!currentSlug) return;
    var nombre     = document.getElementById('ed-nombre').value.trim();
    var precio     = document.getElementById('ed-precio').value;
    var precioText = document.getElementById('ed-preciotexto').value.trim();
    var precioVar  = document.getElementById('ed-preciovariante').value.trim();
    var categoria  = document.getElementById('ed-categoria').value;
    var desc       = document.getElementById('ed-desc').value.trim();
    var dest       = document.getElementById('ed-destacado').checked;

    var msg = [
      '🛠 CAMBIO DE PRODUCTO — Jhugo3D Admin',
      '',
      'Slug: ' + currentSlug,
      'Nombre: ' + nombre,
      'Precio: ' + precio + '€ (visible: ' + precioText + ')',
      precioVar ? 'Precio variante: ' + precioVar : '',
      'Categoría: ' + categoria,
      'Destacado: ' + (dest ? 'Sí' : 'No'),
      '',
      'Descripción:',
      desc,
    ].filter(function(l){ return l !== ''; }).join('\n');

    window.open('https://wa.me/' + WA + '?text=' + encodeURIComponent(msg));
    closeModal();
  });
</script>

</body>
</html>