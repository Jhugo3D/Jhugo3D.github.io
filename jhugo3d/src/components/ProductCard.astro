---
interface Props {
  slug: string;
  nombre: string;
  precio: number;
  precioTexto: string;
  precioVariante?: string;
  categoria: string;
  imagen: string;
  destacado?: boolean;
  lazy?: boolean;
  lang?: string;
  prodPrefix?: string;
}

const {
  slug,
  nombre,
  precio,
  precioTexto,
  precioVariante,
  categoria,
  imagen,
  destacado = false,
  lazy = true,
  lang = 'es',
  prodPrefix = '/producto',
} = Astro.props;

const addLabel: Record<string, string> = { es: '+ Añadir al carrito', ca: '+ Afegir al cistell', en: '+ Add to cart' };
const persLabel: Record<string, string> = { es: '✎ Personalizar', ca: '✎ Personalitzar', en: '✎ Customize' };
const closeLabel: Record<string, string> = { es: '✕ Cerrar personalización', ca: '✕ Tancar personalització', en: '✕ Close customization' };
const notaPlaceholder: Record<string, string> = { es: 'Color, texto, nombre, tamaño...', ca: 'Color, text, nom, mida...', en: 'Color, text, name, size...' };

const catLabels: Record<string, string> = {
  joyeria: 'Joyería',
  soportes: 'Soportes',
  figuras: 'Figuras',
  marcos: 'Marcos',
  decoracion: 'Decoración',
};
---

<div class="product-card card reveal" data-categoria={categoria}>
  <a href={`${prodPrefix}/${slug}`} class="card-link">
    <div class="card-img-wrap">
      <img
        src={imagen}
        alt={nombre}
        loading={lazy ? 'lazy' : 'eager'}
        decoding="async"
        width="400"
        height="400"
      />
      {destacado && <span class="card-badge badge badge-gold">Destacado</span>}
    </div>
    <div class="card-body">
      <span class="card-cat badge">{catLabels[categoria] ?? categoria}</span>
      <h3 class="card-name">{nombre}</h3>
      <div class="card-price">
        <span class="price-num">{precioTexto}</span>
        {precioVariante && <span class="price-variant">{precioVariante}</span>}
      </div>
    </div>
  </a>
  <div class="card-nota-wrap">
    <button class="nota-toggle" type="button" aria-expanded="false"
      data-label-open={persLabel[lang] ?? persLabel.es}
      data-label-close={closeLabel[lang] ?? closeLabel.es}>
      {persLabel[lang] ?? persLabel.es}
    </button>
    <textarea
      class="nota-input"
      placeholder={notaPlaceholder[lang] ?? notaPlaceholder.es}
      rows="2"
      hidden
    ></textarea>
  </div>
  <button
    class="jh-add-btn"
    data-slug={slug}
    data-nombre={nombre}
    data-precio={precio}
    data-preciotexto={precioTexto}
    data-imagen={imagen}
    aria-label={`${addLabel[lang] ?? addLabel.es} ${nombre}`}
  >
    {addLabel[lang] ?? addLabel.es}
  </button>
</div>

<style>
.product-card {
  display: flex;
  flex-direction: column;
}

.card-link {
  display: flex;
  flex-direction: column;
  flex: 1;
  text-decoration: none;
}

.card-img-wrap {
  position: relative;
  aspect-ratio: 1;
  overflow: hidden;
  background: var(--surface-2);
}
.card-img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s var(--ease-out);
}
.product-card:hover .card-img-wrap img { transform: scale(1.04); }

.card-badge {
  position: absolute;
  top: 0.6rem;
  left: 0.6rem;
}

.card-body {
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
  padding: 0.85rem;
  flex: 1;
}

.card-cat { align-self: flex-start; }

.card-name {
  font-family: var(--font-display);
  font-size: 0.9rem;
  font-weight: 600;
  line-height: 1.3;
  color: var(--text);
  flex: 1;
}

/* Nota personalización */
.card-nota-wrap {
  border-top: 1px solid var(--border);
}
.nota-toggle {
  width: 100%;
  padding: 0.55rem 0.85rem;
  background: none;
  border: none;
  color: var(--text-subtle);
  font-family: var(--font-display);
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  cursor: pointer;
  text-align: left;
  transition: color 0.15s, background 0.15s;
}
.nota-toggle:hover { color: var(--gold); background: rgba(212,168,50,0.04); }
.nota-toggle[aria-expanded="true"] { color: var(--gold); }
.nota-input {
  display: block;
  width: 100%;
  padding: 0.6rem 0.85rem;
  background: var(--surface-2);
  border: none;
  border-top: 1px solid var(--border);
  color: var(--text);
  font-family: var(--font-body);
  font-size: 0.8rem;
  line-height: 1.5;
  resize: none;
  outline: none;
  transition: border-color 0.15s;
}
.nota-input:focus { border-color: var(--gold); }
.nota-input::placeholder { color: var(--text-subtle); }

.card-price {
  display: flex;
  align-items: baseline;
  gap: 0.4rem;
  margin-top: 0.25rem;
}
.price-num {
  font-family: var(--font-display);
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--gold);
}
.price-variant {
  font-size: 0.75rem;
  color: var(--text-muted);
}
</style>
