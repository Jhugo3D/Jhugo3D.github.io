---
import { getLang, t } from '../i18n/ui';

const lang = getLang(Astro.url);
const prefix = lang === 'es' ? '' : `/${lang}`;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">

    <div class="footer-brand">
      <a href={`${prefix}/`} class="logo" aria-label="Jhugo3D">
        <span class="logo-j">J</span><span class="logo-rest">hugo</span><span class="logo-3d">3D</span>
      </a>
      <p class="footer-tagline">{t(lang, 'footer.tagline')}</p>
      <div class="footer-social">
        <a href="https://www.instagram.com/jhugo3d/" target="_blank" rel="noopener" aria-label="Instagram @jhugo3d">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
          <span>@jhugo3d</span>
        </a>
        <a href="https://www.tiktok.com/@_jhugo3d_" target="_blank" rel="noopener" aria-label="TikTok @_jhugo3d_">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"/>
          </svg>
          <span>@_jhugo3d_</span>
        </a>
      </div>
    </div>

    <nav class="footer-nav" aria-label="Footer">
      <div class="footer-col">
        <h4>{t(lang, 'footer.tienda')}</h4>
        <ul>
          <li><a href={`${prefix}/catalogo`}>{t(lang, 'nav.catalogo')}</a></li>
          <li><a href={`${prefix}/personalizado`}>{t(lang, 'footer.personalizada')}</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>{t(lang, 'footer.marca')}</h4>
        <ul>
          <li><a href={`${prefix}/proceso`}>{t(lang, 'footer.comoLo')}</a></li>
          <li><a href={`${prefix}/sobre`}>{t(lang, 'footer.sobreHugo')}</a></li>
          <li><a href={`${prefix}/contacto`}>{t(lang, 'nav.contacto')}</a></li>
        </ul>
      </div>
    </nav>

    <div class="footer-contact">
      <h4>{t(lang, 'footer.proyecto')}</h4>
      <a href="mailto:soportejhugo3d@gmail.com" class="contact-email">soportejhugo3d@gmail.com</a>
      <p class="text-muted footer-location">Reus, Tarragona</p>
    </div>

  </div>

  <div class="footer-bottom">
    <div class="container">
      <span>&copy; {year} Jhugo3D. {t(lang, 'footer.derechos')}</span>
      <a href="https://www.instagram.com/nova.agency/" target="_blank" rel="noopener" class="nova-credit">
        <span>Hecho por</span>
        <img src="/img/nova-logo.jpeg" alt="NOVA" class="nova-logo" />
      </a>
    </div>
  </div>
</footer>

<style>
.site-footer {
  position: relative;
  margin-top: auto;
}
.site-footer::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(
    90deg,
    transparent 0%,
    rgba(212,168,50,0.2) 20%,
    rgba(212,168,50,0.55) 50%,
    rgba(212,168,50,0.2) 80%,
    transparent 100%
  );
}

.footer-inner {
  display: grid;
  grid-template-columns: 1.5fr 1fr 1fr;
  gap: 3rem;
  padding-block: 4rem;
}

.logo {
  font-family: var(--font-display);
  font-size: 1.4rem;
  font-weight: 700;
  letter-spacing: -0.03em;
  display: inline-block;
  margin-bottom: 0.75rem;
}
.logo-j    { color: var(--brand-light); }
.logo-rest { color: var(--text); }
.logo-3d   { color: var(--gold); }

.footer-tagline {
  color: var(--text-muted);
  font-style: italic;
  margin-bottom: 1.25rem;
}

.footer-social { display: flex; flex-direction: column; gap: 0.5rem; }
.footer-social a {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  color: var(--text-muted);
  font-size: 0.9rem;
  transition: color 0.15s;
}
.footer-social a:hover { color: var(--gold); }

.footer-nav { display: flex; gap: 2.5rem; }
.footer-col h4 {
  font-family: var(--font-display);
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-subtle);
  margin-bottom: 0.75rem;
}
.footer-col ul { display: flex; flex-direction: column; gap: 0.4rem; }
.footer-col a { color: var(--text-muted); font-size: 0.9rem; transition: color 0.15s; }
.footer-col a:hover { color: var(--text); }

.footer-contact h4 {
  font-family: var(--font-display);
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-subtle);
  margin-bottom: 0.75rem;
}
.contact-email {
  display: block;
  color: var(--gold);
  font-size: 0.9rem;
  word-break: break-all;
  margin-bottom: 0.4rem;
  transition: color 0.15s;
}
.contact-email:hover { color: var(--gold-bright); }
.footer-location { font-size: 0.85rem; margin-top: 0.25rem; }

.footer-bottom { border-top: 1px solid var(--border); }
.footer-bottom .container {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-block: 1.25rem;
  font-size: 0.8rem;
  color: var(--text-subtle);
  flex-wrap: wrap;
  gap: 0.5rem;
}

@media (max-width: 860px) {
  .footer-inner { grid-template-columns: 1fr 1fr; gap: 2rem; }
  .footer-brand { grid-column: 1 / -1; }
}
.nova-credit {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  color: var(--text-subtle);
  font-size: 0.75rem;
  text-decoration: none;
  transition: opacity 0.15s;
  opacity: 0.7;
}
.nova-credit:hover { opacity: 1; }
.nova-logo {
  height: 18px;
  width: auto;
  border-radius: 3px;
  object-fit: contain;
  filter: brightness(0.85);
}

@media (max-width: 560px) {
  .footer-inner { grid-template-columns: 1fr; }
  .footer-nav { gap: 1.5rem; }
  .footer-bottom .container { justify-content: center; text-align: center; flex-direction: column; gap: 0.75rem; }
}
</style>
