---
import { getLang, t, getRouteForLang } from '../i18n/ui';

const lang = getLang(Astro.url);
const path = Astro.url.pathname;
const current = path;

const nav = [
  { key: 'nav.catalogo',      href: `${lang === 'es' ? '' : '/' + lang}/catalogo` },
  { key: 'nav.personalizado', href: `${lang === 'es' ? '' : '/' + lang}/personalizado` },
  { key: 'nav.proceso',       href: `${lang === 'es' ? '' : '/' + lang}/proceso` },
  { key: 'nav.sobre',         href: `${lang === 'es' ? '' : '/' + lang}/sobre` },
  { key: 'nav.contacto',      href: `${lang === 'es' ? '' : '/' + lang}/contacto` },
] as const;

const catHref = lang === 'es' ? '/catalogo' : `/${lang}/catalogo`;
---

<header class="site-header">
  <div class="container header-inner">
    <a href={lang === 'es' ? '/' : `/${lang}`} class="logo" aria-label="Jhugo3D — inicio">
      <span class="logo-j">J</span><span class="logo-rest">hugo</span><span class="logo-3d">3D</span>
    </a>

    <nav class="main-nav" aria-label="Navegación principal">
      <ul>
        {nav.map(({ key, href }) => (
          <li>
            <a href={href} class:list={['nav-link', { active: current.startsWith(href) }]}>
              {t(lang, key as any)}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Language switcher -->
    <div class="lang-switcher" aria-label="Cambiar idioma">
      <a href={getRouteForLang(path, 'es')} class:list={['lang-btn', { 'lang-active': lang === 'es' }]} aria-label="Español">ES</a>
      <span class="lang-sep">·</span>
      <a href={getRouteForLang(path, 'ca')} class:list={['lang-btn', { 'lang-active': lang === 'ca' }]} aria-label="Català">CA</a>
      <span class="lang-sep">·</span>
      <a href={getRouteForLang(path, 'en')} class:list={['lang-btn', { 'lang-active': lang === 'en' }]} aria-label="English">EN</a>
    </div>

    <a href={catHref} class="btn btn-primary header-cta">{t(lang, 'nav.verCatalogo')}</a>

    <button class="menu-toggle" aria-label="Abrir menú" aria-expanded="false" aria-controls="mobile-menu">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="mobile-menu" id="mobile-menu" hidden>
    <nav aria-label="Menú móvil">
      <ul>
        <li><a href={lang === 'es' ? '/' : `/${lang}`} class="mobile-link">Inicio</a></li>
        {nav.map(({ key, href }) => (
          <li><a href={href} class="mobile-link">{t(lang, key as any)}</a></li>
        ))}
      </ul>
      <div class="mobile-lang">
        <a href={getRouteForLang(path, 'es')} class:list={['lang-btn', { 'lang-active': lang === 'es' }]}>ES</a>
        <span class="lang-sep">·</span>
        <a href={getRouteForLang(path, 'ca')} class:list={['lang-btn', { 'lang-active': lang === 'ca' }]}>CA</a>
        <span class="lang-sep">·</span>
        <a href={getRouteForLang(path, 'en')} class:list={['lang-btn', { 'lang-active': lang === 'en' }]}>EN</a>
      </div>
    </nav>
  </div>
</header>

<style>
.site-header {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  border-bottom: 1px solid transparent;
  transition: background 0.3s, border-color 0.3s, backdrop-filter 0.3s;
}
.site-header.scrolled {
  background: rgba(12,12,12,0.88);
  backdrop-filter: blur(16px) saturate(180%);
  -webkit-backdrop-filter: blur(16px) saturate(180%);
  border-color: var(--border);
}

.header-inner {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  height: 64px;
}

.logo {
  font-family: var(--font-display);
  font-size: 1.4rem;
  font-weight: 700;
  letter-spacing: -0.03em;
  flex-shrink: 0;
}
.logo-j    { color: var(--brand-light); }
.logo-rest { color: var(--text); }
.logo-3d   { color: var(--gold); }

.main-nav { flex: 1; }
.main-nav ul { display: flex; gap: 0.25rem; }
.nav-link {
  position: relative;
  font-family: var(--font-display);
  font-size: 0.875rem;
  font-weight: 500;
  padding: 0.4rem 0.75rem;
  border-radius: var(--radius-sm);
  color: var(--text-muted);
  transition: color var(--transition-fast), background var(--transition-fast);
}
.nav-link:hover { color: var(--text); background: var(--surface); }
.nav-link.active { color: var(--gold); background: rgba(212,168,50,0.06); }
.nav-link.active::after {
  content: '';
  position: absolute;
  bottom: 3px; left: 50%;
  transform: translateX(-50%);
  width: 14px; height: 1.5px;
  background: var(--gold);
  border-radius: 2px;
  opacity: 0.8;
}

/* Language switcher */
.lang-switcher {
  display: flex;
  align-items: center;
  gap: 0.25rem;
  flex-shrink: 0;
}
.lang-btn {
  font-family: var(--font-display);
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  color: var(--text-subtle);
  padding: 0.25rem 0.3rem;
  border-radius: var(--radius-sm);
  transition: color var(--transition-fast);
}
.lang-btn:hover { color: var(--text); }
.lang-active { color: var(--gold) !important; }
.lang-sep { color: var(--border-strong); font-size: 0.65rem; }

.header-cta { margin-left: auto; flex-shrink: 0; }

.menu-toggle {
  display: none;
  flex-direction: column;
  gap: 5px;
  padding: 8px;
  margin-left: auto;
}
.menu-toggle span {
  display: block;
  width: 22px; height: 2px;
  background: var(--text);
  border-radius: 2px;
  transition: transform 0.2s, opacity 0.2s;
}
.menu-toggle[aria-expanded="true"] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.menu-toggle[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
.menu-toggle[aria-expanded="true"] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

.mobile-menu {
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  padding: 1rem 0 1.5rem;
}
.mobile-link {
  display: block;
  font-family: var(--font-display);
  font-size: 1.05rem;
  font-weight: 500;
  padding: 0.75rem clamp(1rem, 5vw, 2.5rem);
  color: var(--text-muted);
  border-bottom: 1px solid var(--border);
  transition: color 0.15s;
}
.mobile-link:last-child { border-bottom: none; }
.mobile-link:hover { color: var(--gold); }

.mobile-lang {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.75rem clamp(1rem, 5vw, 2.5rem);
  margin-top: 0.5rem;
}

@media (max-width: 860px) {
  .main-nav, .header-cta, .lang-switcher { display: none; }
  .menu-toggle { display: flex; }
}
</style>

<script>
const header = document.querySelector('.site-header')!;
const btn    = document.querySelector('.menu-toggle')!;
const menu   = document.getElementById('mobile-menu')!;

window.addEventListener('scroll', () => {
  header.classList.toggle('scrolled', window.scrollY > 20);
}, { passive: true });

btn.addEventListener('click', () => {
  const open = btn.getAttribute('aria-expanded') === 'true';
  btn.setAttribute('aria-expanded', String(!open));
  menu.hidden = open;
});
</script>
