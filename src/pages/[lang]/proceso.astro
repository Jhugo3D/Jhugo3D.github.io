---
import Layout from '../../components/Layout.astro';
import { t, type Lang } from '../../i18n/ui';

export function getStaticPaths() {
  return [{ params: { lang: 'ca' } }, { params: { lang: 'en' } }];
}

const { lang } = Astro.params as { lang: Lang };
const prefix = `/${lang}`;

const pasos = [
  { num: '01', titulo: t(lang, 'proc.s1Title'), desc: t(lang, 'proc.s1Desc') },
  { num: '02', titulo: t(lang, 'proc.s2Title'), desc: t(lang, 'proc.s2Desc') },
  { num: '03', titulo: t(lang, 'proc.s3Title'), desc: t(lang, 'proc.s3Desc') },
  { num: '04', titulo: t(lang, 'proc.s4Title'), desc: t(lang, 'proc.s4Desc') },
];
---

<Layout title={t(lang, 'nav.proceso')} description={t(lang, 'proc.sub')}>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">{t(lang, 'proc.eyebrow')}</p>
      <h1>{t(lang, 'proc.heading')}</h1>
      <p class="hero-sub">{t(lang, 'proc.sub')}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="pasos">
        {pasos.map((p, i) => (
          <div class="paso reveal">
            <div class="paso-num">{p.num}</div>
            <div class="paso-body">
              <h2 class="paso-title">{p.titulo}</h2>
              <p class="paso-desc">{p.desc}</p>
            </div>
            {i < pasos.length - 1 && (
              <div class="paso-arrow" aria-hidden="true">↓</div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width: var(--max-w-text);">
      <h2 class="section-title reveal" style="font-size: clamp(1.5rem, 4vw, 2rem);">{t(lang, 'proc.faqTitle')}</h2>
      <div class="faq">
        <details class="faq-item reveal">
          <summary>{t(lang, 'proc.faq1Q')}</summary>
          <p>{t(lang, 'proc.faq1A')}</p>
        </details>
        <details class="faq-item reveal">
          <summary>{t(lang, 'proc.faq2Q')}</summary>
          <p>{t(lang, 'proc.faq2A')}</p>
        </details>
        <details class="faq-item reveal">
          <summary>{t(lang, 'proc.faq3Q')}</summary>
          <p>{t(lang, 'proc.faq3A')} <a href="mailto:soportejhugo3d@gmail.com">soportejhugo3d@gmail.com</a>.</p>
        </details>
        <details class="faq-item reveal">
          <summary>{t(lang, 'proc.faq4Q')}</summary>
          <p>{t(lang, 'proc.faq4A')}</p>
        </details>
      </div>
    </div>
  </section>
</Layout>

<style>
.page-hero { padding-top: calc(64px + 4rem); padding-bottom: 4rem; border-bottom: 1px solid var(--border); }
.page-hero h1 { font-size: clamp(2rem, 6vw, 3.5rem); margin-top: 0.5rem; }
.hero-sub { color: var(--text-muted); max-width: 60ch; margin-top: 1rem; line-height: 1.7; }
.pasos { max-width: 680px; display: flex; flex-direction: column; gap: 0; }
.paso { display: grid; grid-template-columns: 80px 1fr; gap: 1.5rem; position: relative; }
.paso-num { font-family: var(--font-display); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.12em; color: var(--gold); padding-top: 0.2rem; flex-shrink: 0; }
.paso-body { padding-bottom: 2.5rem; }
.paso-title { font-size: 1.35rem; margin-bottom: 0.6rem; }
.paso-desc { color: var(--text-muted); line-height: 1.7; }
.paso-arrow { position: absolute; left: 33px; bottom: 0.5rem; font-size: 1.25rem; color: var(--border-2); }
.faq { display: flex; flex-direction: column; margin-top: 2rem; }
.faq-item { border-bottom: 1px solid var(--border); padding-block: 1.25rem; }
.faq-item summary { font-family: var(--font-display); font-size: 1rem; font-weight: 600; cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; gap: 1rem; }
.faq-item summary::after { content: '+'; font-size: 1.2rem; color: var(--gold); flex-shrink: 0; transition: transform 0.2s; }
.faq-item[open] summary::after { transform: rotate(45deg); }
.faq-item p { margin-top: 0.75rem; color: var(--text-muted); line-height: 1.7; font-size: 0.9rem; }
.faq-item a { color: var(--gold); }
@media (max-width: 600px) { .paso { grid-template-columns: 48px 1fr; gap: 1rem; } }
</style>