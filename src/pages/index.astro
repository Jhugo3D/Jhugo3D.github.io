---
import Layout from '../components/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import { getCollection } from 'astro:content';

const productos = await getCollection('productos');
const destacados = productos
  .filter(p => p.data.destacado)
  .slice(0, 4);

const steps = [
  {
    n: '01',
    title: 'Elige o diseña',
    desc: 'Explora el catálogo y encuentra tu pieza, o cuéntanos tu idea y la hacemos realidad desde cero.',
  },
  {
    n: '02',
    title: 'Imprimimos',
    desc: 'Hugo da vida a tu diseño capa a capa. Cada pieza se revisa antes de salir del taller.',
  },
  {
    n: '03',
    title: 'Lo recibes',
    desc: 'Tu pieza lista en unos días. Escríbenos y te decimos el plazo exacto para tu pedido.',
  },
];
---

<Layout title="Jhugo3D" description="Impresiones 3D personalizadas de todo lo que imagines. Piezas únicas hechas a mano en Reus.">

  <!-- ── Hero ─────────────────────────────────────────── -->
  <section class="hero">

    <video
      class="hero-video"
      src="/video/hero.mp4"
      autoplay
      loop
      muted
      playsinline
      preload="auto"
    ></video>

    <div class="hero-overlay" aria-hidden="true"></div>

    <!-- Starfield -->
    <svg class="hero-stars" viewBox="0 0 1440 900" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
      <g class="star-group" fill="none" stroke="rgba(212,168,50,0.55)" stroke-linecap="round">
        <line x1="112" y1="148" x2="112" y2="156"/><line x1="108" y1="152" x2="116" y2="152"/>
        <line x1="1318" y1="210" x2="1318" y2="218"/><line x1="1314" y1="214" x2="1322" y2="214"/>
        <line x1="245" y1="340" x2="245" y2="348"/><line x1="241" y1="344" x2="249" y2="344"/>
        <line x1="1180" y1="320" x2="1180" y2="328"/><line x1="1176" y1="324" x2="1184" y2="324"/>
        <line x1="68"   y1="520" x2="68"   y2="528"/><line x1="64"   y1="524" x2="72"   y2="524"/>
        <line x1="1390" y1="480" x2="1390" y2="488"/><line x1="1386" y1="484" x2="1394" y2="484"/>
        <line x1="420"  y1="80"  x2="420"  y2="88" /><line x1="416"  y1="84"  x2="424"  y2="84" />
        <line x1="1020" y1="110" x2="1020" y2="118"/><line x1="1016" y1="114" x2="1024" y2="114"/>
        <line x1="580" y1="200" x2="580" y2="205"/><line x1="577" y1="202" x2="583" y2="202"/>
        <line x1="860" y1="400" x2="860" y2="405"/><line x1="857" y1="402" x2="863" y2="402"/>
        <circle cx="730" cy="140" r="1.2"/><circle cx="190" cy="430" r="1"/>
        <circle cx="1260" cy="380" r="1.2"/><circle cx="650" cy="490" r="1"/>
      </g>
    </svg>

    <div class="container hero-content">
      <span class="eyebrow hero-eyebrow">Impresión 3D · Reus</span>
      <h1 class="hero-title">
        Imprime lo<br />
        <span class="text-gold">que imaginas.</span>
      </h1>
      <p class="hero-sub">
        Piezas únicas impresas bajo demanda. Diseños del catálogo o a tu medida —
        nada es imposible, solo tienes que creerlo.
      </p>
      <div class="hero-actions">
        <a href="/catalogo" class="btn btn-primary">Ver catálogo →</a>
        <a href="/personalizado" class="btn btn-outline">Pedir personalizado</a>
      </div>
    </div>

    <div class="hero-stats container">
      <div class="stat">
        <span class="stat-n">101</span>
        <span class="stat-l">Publicaciones</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-n">48+</span>
        <span class="stat-l">Diseños en catálogo</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-n">3€</span>
        <span class="stat-l">Desde</span>
      </div>
    </div>

    <div class="scroll-hint" aria-hidden="true">
      <div class="scroll-line"></div>
    </div>

  </section>

  <!-- ── Marquee ticker ───────────────────────────────── -->
  <div class="marquee-outer" aria-hidden="true">
    <div class="marquee-track">
      <span class="marquee-item">Impresión 3D</span><span class="marquee-sep">✦</span>
      <span class="marquee-item">Reus, Tarragona</span><span class="marquee-sep">✦</span>
      <span class="marquee-item">PLA · PETG · Silk</span><span class="marquee-sep">✦</span>
      <span class="marquee-item">Personalizado</span><span class="marquee-sep">✦</span>
      <span class="marquee-item">48 Diseños</span><span class="marquee-sep">✦</span>
      <span class="marquee-item">Desde 3€</span><span class="marquee-sep">✦</span>
      <span class="marquee-item">Hecho a mano</span><span class="marquee-sep">✦</span>
      <span class="marquee-item">Entrega rápida</span><span class="marquee-sep">✦</span>
      <span class="marquee-item">Impresión 3D</span><span class="marquee-sep">✦</span>
      <span class="marquee-item">Reus, Tarragona</span><span class="marquee-sep">✦</span>
      <span class="marquee-item">PLA · PETG · Silk</span><span class="marquee-sep">✦</span>
      <span class="marquee-item">Personalizado</span><span class="marquee-sep">✦</span>
      <span class="marquee-item">48 Diseños</span><span class="marquee-sep">✦</span>
      <span class="marquee-item">Desde 3€</span><span class="marquee-sep">✦</span>
      <span class="marquee-item">Hecho a mano</span><span class="marquee-sep">✦</span>
      <span class="marquee-item">Entrega rápida</span><span class="marquee-sep">✦</span>
    </div>
  </div>

  <!-- ── Destacados ────────────────────────────────────── -->
  {destacados.length > 0 && (
    <section class="section">
      <div class="container">
        <p class="eyebrow">Más populares</p>
        <h2 class="section-title">Diseños destacados</h2>
        <p class="section-sub">Una selección de piezas del catálogo. Disponibles ahora, listas en días.</p>
        <div class="product-grid">
          {destacados.map((p, i) => (
            <ProductCard
              slug={p.slug}
              nombre={p.data.nombre}
              precio={p.data.precio}
              precioTexto={p.data.precioTexto}
              precioVariante={p.data.precioVariante}
              categoria={p.data.categoria}
              imagen={p.data.imagen}
              destacado={true}
              lazy={i > 1}
            />
          ))}
        </div>
        <div class="all-cta">
          <a href="/catalogo" class="btn btn-outline">Ver los 48 diseños →</a>
        </div>
      </div>
    </section>
  )}

  <!-- ── Cómo trabajamos ───────────────────────────────── -->
  <section class="section how-section section--bordered">
    <div class="container">
      <p class="eyebrow reveal">El proceso</p>
      <h2 class="section-title reveal">Cómo trabajamos</h2>
      <p class="section-sub reveal">Tres pasos. Sin complicaciones.</p>
      <div class="steps">
        {steps.map(s => (
          <div class="step reveal">
            <span class="step-n">{s.n}</span>
            <h3 class="step-title">{s.title}</h3>
            <p class="step-desc">{s.desc}</p>
          </div>
        ))}
      </div>
      <div class="reveal" style="margin-top: 2.5rem; display: flex; gap: 1rem; flex-wrap: wrap;">
        <a href="/proceso" class="btn btn-ghost">Más sobre el proceso →</a>
      </div>
    </div>
  </section>

  <!-- ── CTA Banner ────────────────────────────────────── -->
  <section class="cta-banner">
    <div class="container cta-inner">
      <div class="cta-text reveal">
        <h2>¿Tienes algo en mente?</h2>
        <p>Cuéntanos tu idea y la imprimimos. Sugerencias al DM o directamente al correo.</p>
      </div>
      <div class="cta-actions reveal">
        <a href="/personalizado" class="btn btn-primary">Pedir personalizado →</a>
        <a href="mailto:soportejhugo3d@gmail.com" class="btn btn-outline">Escribir email</a>
      </div>
    </div>
  </section>

</Layout>

<style>
/* ── Hero ──────────────────────────────────────────────── */
.hero {
  position: relative;
  height: 100svh;
  width: 100%;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.hero-video {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 0;
}

.hero-overlay {
  position: absolute;
  inset: 0;
  z-index: 1;
  background:
    radial-gradient(ellipse 65% 55% at 12% 50%, rgba(212,168,50,0.07) 0%, transparent 65%),
    radial-gradient(ellipse 55% 65% at 88% 52%, rgba(27,60,135,0.1) 0%, transparent 65%),
    linear-gradient(to top,  rgba(8,8,8,0.96) 0%, rgba(8,8,8,0.45) 42%, transparent 65%),
    linear-gradient(to bottom, rgba(8,8,8,0.55) 0%, transparent 32%),
    rgba(0,0,0,0.2);
}

.hero-content {
  position: relative;
  z-index: 2;
  padding-top: 80px;
  padding-bottom: 120px;
}

/* ── Hero text entrance ─── */
@keyframes hero-rise {
  from { opacity: 0; transform: translateY(48px); }
  to   { opacity: 1; transform: translateY(0); }
}
.hero-eyebrow  { animation: hero-rise 0.8s var(--ease-out) 0.05s both; display: block; margin-bottom: 1.25rem; }
.hero-title    { animation: hero-rise 0.9s var(--ease-out) 0.2s  both; }
.hero-sub      { animation: hero-rise 0.9s var(--ease-out) 0.4s  both; }
.hero-actions  { animation: hero-rise 0.8s var(--ease-out) 0.58s both; }
@media (prefers-reduced-motion: reduce) {
  .hero-eyebrow, .hero-title, .hero-sub, .hero-actions { animation: none; }
}

.hero-title {
  font-size: clamp(3rem, 9vw, 6.5rem);
  line-height: 1.0;
  margin-bottom: 1.5rem;
}

/* Gradient text en el headline del hero */
.hero-title .text-gold {
  background: linear-gradient(130deg, #B8850A 0%, #F0C040 40%, #D4A832 70%, #E8C060 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  filter: drop-shadow(0 2px 24px rgba(212,168,50,0.22));
}

.hero-sub {
  font-size: clamp(1rem, 2vw, 1.15rem);
  color: rgba(240,240,240,0.65);
  max-width: 52ch;
  margin-bottom: 2.25rem;
  line-height: var(--leading-relaxed);
}

.hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

/* Stats pegadas al fondo */
.hero-stats {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  z-index: 2;
  display: flex;
  align-items: center;
  gap: 2.5rem;
  padding-block: 1.25rem 1.75rem;
  flex-wrap: wrap;
  background: linear-gradient(to top, rgba(8,8,8,0.75) 0%, transparent 100%);
}
.stat { display: flex; flex-direction: column; }
.stat-n {
  font-family: var(--font-display);
  font-size: 2rem;
  font-weight: 700;
  color: var(--gold);
  line-height: 1;
  letter-spacing: -0.03em;
}
.stat-l {
  font-size: 0.75rem;
  font-family: var(--font-display);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.4);
  margin-top: 0.25rem;
}
.stat-divider { width: 1px; height: 36px; background: rgba(255,255,255,0.1); }

/* Indicador scroll */
.scroll-hint {
  position: absolute;
  bottom: 5.5rem;
  left: 50%;
  transform: translateX(-50%);
  z-index: 3;
}
.scroll-line {
  width: 1px;
  height: 44px;
  background: linear-gradient(to bottom, rgba(212,168,50,0.8), transparent);
  animation: jh-line 1.8s infinite;
}
@keyframes jh-line {
  0%   { transform: scaleY(0); transform-origin: top; opacity: 1; }
  50%  { transform: scaleY(1); transform-origin: top; opacity: 1; }
  51%  { transform: scaleY(1); transform-origin: bottom; }
  100% { transform: scaleY(0); transform-origin: bottom; opacity: 0; }
}

@media (prefers-reduced-motion: reduce) {
  .scroll-hint { display: none; }
}

/* ── Steps ────────────────────────────────────────────── */
.how-section { background: var(--surface); }

.steps {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
  margin-top: 0.5rem;
}
.step {
  padding: 2rem;
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  position: relative;
  overflow: hidden;
}
.step::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, transparent 0%, var(--brand) 20%, var(--gold) 80%, transparent 100%);
  opacity: 0.9;
}
.step-n {
  display: block;
  font-family: var(--font-display);
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  color: var(--gold);
  margin-bottom: 0.75rem;
}
.step-title {
  font-size: 1.15rem;
  margin-bottom: 0.6rem;
}
.step-desc { color: var(--text-muted); font-size: 0.9rem; line-height: 1.6; }

/* ── CTA Banner ───────────────────────────────────────── */
.cta-banner {
  background: var(--surface);
  border-top: 1px solid var(--border);
  padding-block: 5rem;
}
.cta-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
  flex-wrap: wrap;
}
.cta-text h2 { font-size: clamp(1.5rem, 4vw, 2.25rem); margin-bottom: 0.5rem; }
.cta-text p  { color: var(--text-muted); max-width: 48ch; }
.cta-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

.all-cta {
  text-align: center;
  margin-top: 3rem;
}

@media (max-width: 760px) {
  .steps { grid-template-columns: 1fr; }
  .cta-inner { flex-direction: column; }
}
@media (max-width: 480px) {
  .hero-actions { flex-direction: column; }
  .hero-stats { gap: 1.25rem; }
  .stat-divider { display: none; }
}
</style>


