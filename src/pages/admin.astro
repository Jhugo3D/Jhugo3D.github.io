    <p class="login-err" id="l-err">Email o contrasenya incorrectes.</p>
  </div>
</div>

<!-- PANEL -->
<div id="admin-panel">
  <div class="adm-header">
    <div style="display:flex;align-items:center">
      <span class="adm-logo">Jhugo3D</span>
      <div class="adm-tabs">
        <button class="adm-tab active" data-tab="add">✚ Nou producte</button>
        <button class="adm-tab" data-tab="list">☰ Productes</button>
        <button class="adm-tab" data-tab="cfg">⚙ GitHub</button>
      </div>
    </div>
    <button class="btn-sm" id="logout-btn">Sortir</button>
  </div>

  <div class="adm-body">

    <!-- ═══ TAB NOU PRODUCTE ═══ -->
    <div class="tab-panel active" id="tab-add">
      <p class="sec-title">Com vols afegir el producte?</p>
      <div class="mode-selector">
        <button class="mode-btn active gh" data-mode="github" id="mode-gh">
          ⚡ Automàtic via GitHub<br><span style="font-size:.7rem;font-weight:400;opacity:.7">El producte s'afegeix sol (cal token)</span>
        </button>
        <button class="mode-btn" data-mode="manual" id="mode-manual">
          📥 Descarregar fitxers<br><span style="font-size:.7rem;font-weight:400;opacity:.7">Sempre funciona, sense token</span>
