---
import { getCollection } from 'astro:content';

const productos = await getCollection('productos');
const productosData = productos.map(p => ({
  slug: p.slug,
  nombre: p.data.nombre,
  precio: p.data.precio,
  precioTexto: p.data.precioTexto,
  precioVariante: p.data.precioVariante ?? '',
  categoria: p.data.categoria,
  imagen: p.data.imagen,
  descripcion: p.data.descripcion ?? '',
  destacado: p.data.destacado ?? false,
}));
const nextNum = String(productosData.length + 1).padStart(2, '0');
const nextSlug = 'p' + nextNum;
---

<html lang="ca">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin — Jhugo3D</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', system-ui, sans-serif; background: #0a0a0a; color: #f0f0f0; min-height: 100vh; }

    /* LOGIN */
    #login-screen { display:flex; align-items:center; justify-content:center; min-height:100vh; padding:2rem; }
    .login-card { background:#151515; border:1px solid #232323; border-radius:12px; padding:2.5rem; width:100%; max-width:380px; }
    .login-logo { font-size:1.1rem; font-weight:800; color:#D4A832; margin-bottom:1.5rem; display:block; }
    .login-card h1 { font-size:1.35rem; margin-bottom:.3rem; }
    .login-card > p { color:#555; font-size:.85rem; margin-bottom:2rem; }
    .login-err { color:#e44; font-size:.8rem; margin-top:.75rem; text-align:center; display:none; }

    /* PANEL */
    #admin-panel { display:none; }
    .adm-header { background:#0d0d0d; border-bottom:1px solid #1a1a1a; padding:.75rem 1.5rem; display:flex; align-items:center; justify-content:space-between; position:sticky; top:0; z-index:50; }
    .adm-logo { font-weight:800; color:#D4A832; font-size:.95rem; margin-right:1.5rem; }
    .adm-tabs { display:flex; gap:.2rem; }
    .adm-tab { background:none; border:none; color:#555; font-size:.82rem; font-weight:600; padding:.4rem .85rem; border-radius:6px; cursor:pointer; transition:all .15s; }
    .adm-tab.active { background:#1a1a1a; color:#D4A832; }
    .adm-tab:hover:not(.active) { color:#f0f0f0; }
    .btn-sm { background:none; border:1px solid #2e2e2e; border-radius:6px; color:#555; font-size:.72rem; padding:.3rem .7rem; cursor:pointer; transition:all .15s; }
    .btn-sm:hover { border-color:#e44; color:#e44; }

    .adm-body { padding:2rem 1.5rem; max-width:860px; margin:0 auto; }
    .tab-panel { display:none; }
    .tab-panel.active { display:block; }

    /* FORM */
    .sec-title { font-size:.7rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:#444; margin-bottom:1.25rem; padding-bottom:.5rem; border-bottom:1px solid #181818; }
    .form-grid { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
    .full { grid-column:1/-1; }
    .field { display:flex; flex-direction:column; gap:.35rem; }
    .field label { font-size:.72rem; font-weight:600; color:#666; letter-spacing:.04em; text-transform:uppercase; }
    .field input, .field textarea, .field select {
      background:#0d0d0d; border:1.5px solid #1e1e1e; border-radius:8px;
      padding:.65rem .9rem; color:#f0f0f0; font-size:.875rem; outline:none;
      transition:border-color .15s; width:100%; font-family:inherit;
    }
    .field input:focus, .field textarea:focus, .field select:focus { border-color:#D4A832; }
    .field textarea { resize:vertical; min-height:90px; }
    .hint { font-size:.7rem; color:#444; }
    .check-row { display:flex; align-items:center; gap:.5rem; cursor:pointer; font-size:.875rem; color:#888; padding:.5rem 0; }
    .check-row input { accent-color:#D4A832; width:15px; height:15px; }

    /* Image drop */
    .img-drop { border:2px dashed #1e1e1e; border-radius:8px; padding:1.5rem; text-align:center; cursor:pointer; transition:all .2s; position:relative; }
    .img-drop:hover, .img-drop.over { border-color:#D4A832; background:rgba(212,168,50,.04); }
    .img-drop input { position:absolute; inset:0; opacity:0; cursor:pointer; width:100%; height:100%; }
    .img-drop-icon { font-size:1.75rem; opacity:.35; margin-bottom:.4rem; }
    .img-drop-text { font-size:.8rem; color:#555; }
    .img-preview { max-width:100%; max-height:160px; border-radius:6px; object-fit:contain; display:none; margin:.75rem auto 0; }

    /* Buttons */
    .btn-primary { width:100%; padding:.85rem; background:#D4A832; border:none; border-radius:8px; color:#080808; font-weight:700; font-size:.9rem; cursor:pointer; transition:background .15s; margin-top:1.5rem; }
    .btn-primary:hover { background:#F0C040; }
    .btn-primary:disabled { background:#1e1e1e; color:#444; cursor:not-allowed; }
    .btn-secondary { padding:.65rem 1.25rem; background:none; border:1px solid #2e2e2e; border-radius:8px; color:#888; font-size:.85rem; cursor:pointer; transition:all .15s; }
    .btn-secondary:hover { border-color:#888; color:#f0f0f0; }
    .btn-green { padding:.65rem 1.25rem; background:#25D366; border:none; border-radius:8px; color:#fff; font-weight:700; font-size:.85rem; cursor:pointer; transition:background .15s; }
    .btn-green:hover { background:#1ebe57; }

    /* Status */
    .status { border-radius:8px; padding:1rem 1.25rem; margin-top:1.25rem; font-size:.875rem; display:none; line-height:1.5; }
    .status.ok      { background:rgba(37,211,102,.1); border:1px solid rgba(37,211,102,.3); color:#25d366; }
    .status.err     { background:rgba(228,68,68,.1);  border:1px solid rgba(228,68,68,.3);  color:#e44444; }
    .status.loading { background:rgba(212,168,50,.08);border:1px solid rgba(212,168,50,.2); color:#D4A832; }
    .status.info    { background:rgba(100,149,237,.08);border:1px solid rgba(100,149,237,.2);color:#7ab0ff; }

    /* Mode selector */
    .mode-selector { display:flex; gap:.5rem; margin-bottom:2rem; padding:.5rem; background:#0d0d0d; border:1px solid #1a1a1a; border-radius:10px; }
    .mode-btn { flex:1; padding:.65rem; border:none; border-radius:7px; cursor:pointer; font-size:.82rem; font-weight:600; transition:all .15s; background:none; color:#555; }
    .mode-btn.active { background:#1e1e1e; color:#f0f0f0; }
    .mode-btn.active.gh { color:#D4A832; }

    /* Steps */
    .steps-box { background:#0d0d0d; border:1px solid #1a1a1a; border-radius:10px; padding:1.25rem; margin-top:1.25rem; }
    .steps-box h4 { font-size:.8rem; font-weight:700; margin-bottom:1rem; color:#888; }
    .step-item { display:flex; gap:.75rem; align-items:flex-start; margin-bottom:.75rem; font-size:.82rem; color:#777; }
    .step-item:last-child { margin-bottom:0; }
    .step-n { width:20px; height:20px; border-radius:50%; background:#D4A832; color:#080808; font-weight:700; font-size:.65rem; display:flex; align-items:center; justify-content:center; flex-shrink:0; margin-top:.05rem; }
    .step-item strong { color:#aaa; }
    .step-item code { background:#1a1a1a; padding:.1rem .35rem; border-radius:4px; font-size:.75rem; color:#D4A832; }

    /* Result card */
    .result-card { background:#0d0d0d; border:1px solid #1a1a1a; border-radius:10px; padding:1.25rem; margin-top:1rem; display:none; }
    .result-card h4 { font-size:.82rem; font-weight:700; color:#888; margin-bottom:.75rem; }
    .md-box { background:#060606; border:1px solid #1a1a1a; border-radius:6px; padding:.85rem 1rem; font-family:monospace; font-size:.72rem; color:#aaa; white-space:pre; overflow-x:auto; margin-bottom:.75rem; max-height:220px; overflow-y:auto; }
    .result-actions { display:flex; gap:.75rem; flex-wrap:wrap; }

    /* Stats */
    .stats-row { display:flex; gap:.75rem; margin-bottom:2rem; flex-wrap:wrap; }
    .stat-card { background:#0d0d0d; border:1px solid #1a1a1a; border-radius:8px; padding:.9rem 1.25rem; }
    .stat-card .n { font-size:1.6rem; font-weight:700; color:#D4A832; line-height:1; }
    .stat-card .l { font-size:.68rem; color:#555; text-transform:uppercase; letter-spacing:.06em; margin-top:.2rem; }

    /* Table */
    .prod-table { width:100%; border-collapse:collapse; }
    .prod-table th { text-align:left; font-size:.68rem; font-weight:700; letter-spacing:.07em; text-transform:uppercase; color:#3a3a3a; padding:.5rem .75rem; border-bottom:1px solid #1a1a1a; }
    .prod-table td { padding:.55rem .75rem; border-bottom:1px solid #111; font-size:.82rem; vertical-align:middle; }
    .prod-table tr:hover td { background:#0d0d0d; }
    .prod-img-sm { width:34px; height:34px; border-radius:5px; object-fit:cover; background:#1e1e1e; }
    .cat-pill { display:inline-block; padding:.1rem .45rem; background:#151515; border:1px solid #2a2a2a; border-radius:100px; font-size:.67rem; color:#555; }
    .gold-dot { display:inline-block; width:7px; height:7px; border-radius:50%; background:#D4A832; }

    @media (max-width:600px) { .form-grid { grid-template-columns:1fr; } .adm-tabs { gap:0; } .adm-tab { padding:.4rem .55rem; font-size:.75rem; } }
  </style>
</head>
<body>

<!-- LOGIN -->
<div id="login-screen">
  <div class="login-card">
    <span class="login-logo">Jhugo3D ✦ Admin</span>
    <h1>Benvingut de nou</h1>
    <p>Accés restringit al propietari.</p>
    <div class="field" style="margin-bottom:.85rem">
      <label>Email</label>
      <input type="email" id="l-email" placeholder="soportejhugo3d@gmail.com" autocomplete="email" />
