        <div class="result-actions">
          <button class="btn-secondary" id="copy-md-btn">📋 Copiar contingut</button>
          <button class="btn-green" id="dl-img-btn">⬇ Descarregar imatge</button>
        </div>
      </div>
    </div>

    <!-- ═══ TAB PRODUCTES ═══ -->
    <div class="tab-panel" id="tab-list">
      <div class="stats-row">
        <div class="stat-card"><div class="n" id="st-total">0</div><div class="l">Productes</div></div>
        <div class="stat-card"><div class="n" id="st-dest">0</div><div class="l">Destacats</div></div>
        <div class="stat-card"><div class="n" id="st-min">—</div><div class="l">Preu mínim</div></div>
      </div>
      <p class="sec-title">Tots els productes</p>
      <table class="prod-table">
        <thead><tr><th></th><th>Nom</th><th>Preu</th><th>Categoria</th><th>★</th></tr></thead>
        <tbody id="p-tbody"></tbody>
      </table>
    </div>

    <!-- ═══ TAB GITHUB ═══ -->
    <div class="tab-panel" id="tab-cfg">
      <p class="sec-title">Connexió automàtica amb GitHub</p>
      <p style="color:#555;font-size:.82rem;line-height:1.6;margin-bottom:1.5rem">
        Configurant el token de GitHub, els productes nous s'afegiran directament a la web sense cap pas manual.<br>
        <strong style="color:#888">Sense token</strong>, el mode "Descarregar fitxers" sempre funcionarà igualment.
      </p>
      <div class="steps-box" style="margin-bottom:1.5rem">
        <h4>Com obtenir el token:</h4>
        <div class="step-item"><div class="step-n">1</div><div>Ves a <a href="https://github.com/settings/tokens/new?scopes=repo&description=Jhugo3D+Admin" target="_blank" style="color:#D4A832">github.com/settings/tokens/new</a></div></div>
        <div class="step-item"><div class="step-n">2</div><div>Marca el permís <code>repo</code></div></div>
        <div class="step-item"><div class="step-n">3</div><div>Clica "Generate token" i copia el codi <code>ghp_...</code></div></div>
        <div class="step-item"><div class="step-n">4</div><div>Enganxa'l aquí i guarda</div></div>
      </div>
      <div class="form-grid" style="max-width:500px">
        <div class="field">
          <label>Usuari de GitHub</label>
          <input type="text" id="cfg-user" placeholder="el-teu-usuari" />
        </div>
        <div class="field">
          <label>Nom del repositori</label>
          <input type="text" id="cfg-repo" placeholder="jhugo3d" />
        </div>
        <div class="field full">
          <label>Token (ghp_...)</label>
          <input type="password" id="cfg-token" placeholder="ghp_xxxxxxxxxxxxxxxxxxxx" />
          <span class="hint">Es guarda al teu navegador. Ningú més pot veure'l.</span>
        </div>
      </div>
      <button class="btn-primary" id="cfg-save" style="max-width:200px;margin-top:.75rem">Guardar</button>
      <div class="status" id="cfg-status"></div>
    </div>

  </div>
</div>

<script is:inline define:vars={{ productosData, nextSlug }}>
var P = productosData;
var CRED = { email: 'soportejhugo3d@gmail.com', pass: 'Quim guapo' };
var mode = 'github';
var imgB64 = null, imgExt = 'jpg', imgFilename = '';

/* ─ AUTH ─ */
function logged() { return sessionStorage.getItem('jh_adm') === '1'; }
function showPanel() {
  document.getElementById('login-screen').style.display = 'none';
  document.getElementById('admin-panel').style.display = 'block';
  loadCfg(); renderList();
  document.getElementById('f-slug').value = nextSlug;
  updateModeUI();
}
if (logged()) showPanel();

function tryLogin() {
  var e = document.getElementById('l-email').value.trim();
  var p = document.getElementById('l-pass').value;
  if (e === CRED.email && p === CRED.pass) {
    sessionStorage.setItem('jh_adm', '1');
    document.getElementById('l-err').style.display = 'none';
    showPanel();
  } else { document.getElementById('l-err').style.display = 'block'; }
}
document.getElementById('l-btn').onclick = tryLogin;
document.getElementById('l-email').onkeydown = function(e){ if(e.key==='Enter') tryLogin(); };
document.getElementById('l-pass').onkeydown  = function(e){ if(e.key==='Enter') tryLogin(); };
document.getElementById('logout-btn').onclick = function(){ sessionStorage.removeItem('jh_adm'); location.reload(); };

/* ─ TABS ─ */
document.querySelectorAll('.adm-tab').forEach(function(t){
  t.onclick = function(){
    document.querySelectorAll('.adm-tab').forEach(function(x){ x.classList.remove('active'); });
    document.querySelectorAll('.tab-panel').forEach(function(x){ x.classList.remove('active'); });
    t.classList.add('active');
    document.getElementById('tab-'+t.dataset.tab).classList.add('active');
  };
});

/* ─ MODE ─ */
document.getElementById('mode-gh').onclick = function(){ mode='github'; updateModeUI(); };
document.getElementById('mode-manual').onclick = function(){ mode='manual'; updateModeUI(); };
function updateModeUI(){
  var ghBtn = document.getElementById('mode-gh');
  var manBtn = document.getElementById('mode-manual');
  ghBtn.classList.toggle('active', mode==='github');
  ghBtn.classList.toggle('gh', mode==='github');
  manBtn.classList.toggle('active', mode==='manual');
  document.getElementById('f-submit').textContent = mode==='github'
    ? '⚡ Afegir producte a la web'
    : '📥 Generar fitxers per descarregar';
}

/* ─ IMAGE ─ */
document.getElementById('f-img').onchange = function(e){
  var file = e.target.files[0]; if(!file) return;
  imgExt = file.name.split('.').pop().toLowerCase();
  var rd = new FileReader();
  rd.onload = function(ev){
    imgB64 = ev.target.result.split(',')[1];
    imgFilename = file.name;
    var prev = document.getElementById('img-prev');
    prev.src = ev.target.result; prev.style.display = 'block';
    document.getElementById('img-ph').style.display = 'none';
  };
  rd.readAsDataURL(file);
};
['dragover','dragleave','drop'].forEach(function(ev){
  document.getElementById('img-drop').addEventListener(ev,function(e){
    e.preventDefault();
    this.classList.toggle('over', ev==='dragover');
  });
});

/* ─ AUTO SLUG ─ */
document.getElementById('f-nom').oninput = function(){
  var cur = document.getElementById('f-slug').value;
  if(cur===nextSlug||cur===''){
    var s = this.value.toLowerCase()
      .normalize('NFD').replace(/[̀-ͯ]/g,'')
      .replace(/[^a-z0-9]+/g,'-').replace(/^-+|-+$/g,'').substring(0,30);
    document.getElementById('f-slug').value = s||nextSlug;
  }
};

/* ─ GITHUB API ─ */
function ghPut(path, content, msg, token, owner, repo){
  return fetch('https://api.github.com/repos/'+owner+'/'+repo+'/contents/'+path,{
    method:'PUT',
    headers:{'Authorization':'token '+token,'Content-Type':'application/json','Accept':'application/vnd.github+json'},
    body:JSON.stringify({message:msg,content:content})
  }).then(function(r){
    if(!r.ok) return r.json().then(function(d){throw new Error(d.message||r.status);});
    return r.json();
  });
}
function b64utf8(str){ return btoa(unescape(encodeURIComponent(str))); }

/* ─ BUILD MD ─ */
function buildMd(slug){
  var nom    = document.getElementById('f-nom').value.trim();
  var preu   = document.getElementById('f-preu').value;
  var preutx = document.getElementById('f-preutxt').value.trim();
  var preuv  = document.getElementById('f-preuvar').value.trim();
  var cat    = document.getElementById('f-cat').value;
  var dest   = document.getElementById('f-dest').checked;
  var desc   = document.getElementById('f-desc').value.trim();
  var ext    = imgExt||'jpg';
  var lines = [
    '---',
    'nombre: "'+nom.replace(/"/g,'\\"')+'"',
    'precio: '+preu,
    'precioTexto: "'+preutx+'"',
    preuv ? 'precioVariante: "'+preuv+'"' : null,
    'categoria: "'+cat+'"',
    'imagen: "/img/productos/'+slug+'.'+ext+'"',
    'descripcion: "'+desc.replace(/"/g,'\\"').replace(/\n/g,' ')+'"',
    'destacado: '+dest,
    '---',
    '',
    desc,
  ].filter(function(l){return l!==null;}).join('\n');
  return lines;
}

/* ─ SUBMIT ─ */
document.getElementById('prod-form').onsubmit = function(e){
  e.preventDefault();
  var slug = document.getElementById('f-slug').value.trim();
  if(!imgB64){ showStatus('f-status','err','⚠ Afegeix una foto del producte.'); return; }

  if(mode==='manual'){
    doManual(slug); return;
  }

  var u = localStorage.getItem('jh_u');
  var r = localStorage.getItem('jh_r');
  var t = localStorage.getItem('jh_t');
  if(!u||!r||!t){
    showStatus('f-status','info',
      '⚠ No tens el token de GitHub configurat.<br>'+
      '<span style="font-size:.8rem">Ves a la pestanya <strong>⚙ GitHub</strong> per configurar-lo, '+
      'o utilitza el mode <strong>"Descarregar fitxers"</strong> de dalt.</span>'
    );
    return;
  }
  doGitHub(slug, u, r, t);
};

function doGitHub(slug, u, r, t){
  var nom = document.getElementById('f-nom').value.trim();
  var btn = document.getElementById('f-submit');
  btn.disabled = true;
  showStatus('f-status','loading','⏳ Pujant la imatge...');
  var ext = imgExt||'jpg';
  ghPut('public/img/productos/'+slug+'.'+ext, imgB64, 'Add image: '+nom, t, u, r)
    .then(function(){
      showStatus('f-status','loading','⏳ Creant el producte...');
      return ghPut('src/content/productos/'+slug+'.md', b64utf8(buildMd(slug)), 'Add product: '+nom, t, u, r);
    })
    .then(function(){
      showStatus('f-status','ok',
        '✓ Producte "'+nom+'" afegit!<br>'+
        '<span style="font-size:.8rem;opacity:.8">La web s\'actualitzarà en ~2 minuts.</span>'
      );
      btn.disabled=false;
      resetForm();
    })
    .catch(function(err){
      showStatus('f-status','err','✗ Error: '+err.message+'<br><span style="font-size:.78rem">Comprova el token a la pestanya ⚙ GitHub.</span>');
      btn.disabled=false;
    });
}

function doManual(slug){
  var md = buildMd(slug);
  document.getElementById('md-output').textContent = md;
  var card = document.getElementById('result-card');
  card.style.display = 'block';
  card.scrollIntoView({behavior:'smooth',block:'start'});
  showStatus('f-status','ok','✓ Fitxers generats. Segueix els passos de baix per pujar-los a GitHub.');
}

document.getElementById('copy-md-btn').onclick = function(){
  navigator.clipboard.writeText(document.getElementById('md-output').textContent).then(function(){
    document.getElementById('copy-md-btn').textContent = '✓ Copiat!';
    setTimeout(function(){ document.getElementById('copy-md-btn').textContent = '📋 Copiar contingut'; }, 2000);
  });
};

document.getElementById('dl-img-btn').onclick = function(){
  if(!imgB64) return;
  var slug = document.getElementById('f-slug').value.trim();
  var ext  = imgExt||'jpg';
  var a = document.createElement('a');
  a.href = 'data:image/'+ext+';base64,'+imgB64;
  a.download = slug+'.'+ext;
  a.click();
};

function resetForm(){
  document.getElementById('prod-form').reset();
  document.getElementById('img-prev').style.display='none';
  document.getElementById('img-ph').style.display='block';
  document.getElementById('result-card').style.display='none';
  imgB64=null;
  document.getElementById('f-slug').value=nextSlug;
}

/* ─ CONFIG ─ */
function loadCfg(){
  var u=localStorage.getItem('jh_u')||'';
  var r=localStorage.getItem('jh_r')||'';
  var t=localStorage.getItem('jh_t')||'';
  document.getElementById('cfg-user').value=u;
  document.getElementById('cfg-repo').value=r;
  document.getElementById('cfg-token').value=t;
}
document.getElementById('cfg-save').onclick = function(){
  var u=document.getElementById('cfg-user').value.trim();
  var r=document.getElementById('cfg-repo').value.trim();
  var t=document.getElementById('cfg-token').value.trim();
  localStorage.setItem('jh_u',u);
  localStorage.setItem('jh_r',r);
  localStorage.setItem('jh_t',t);
  showStatus('cfg-status','ok','✓ Configuració guardada. Ara pots usar el mode automàtic.');
};

/* ─ LIST ─ */
function renderList(){
  var dest=P.filter(function(p){return p.destacado;}).length;
  var prices=P.map(function(p){return p.precio;});
  document.getElementById('st-total').textContent=P.length;
  document.getElementById('st-dest').textContent=dest;
  document.getElementById('st-min').textContent=Math.min.apply(null,prices)+'€';
  document.getElementById('p-tbody').innerHTML=P.map(function(p){
    return '<tr>'+
      '<td><img class="prod-img-sm" src="'+p.imagen+'" alt="" loading="lazy"></td>'+
      '<td style="font-weight:600">'+p.nombre+'</td>'+
      '<td style="color:#D4A832;font-weight:700">'+p.precioTexto+'</td>'+
      '<td><span class="cat-pill">'+p.categoria+'</span></td>'+
      '<td>'+(p.destacado?'<span class="gold-dot"></span>':'')+'</td>'+
    '</tr>';
  }).join('');
}

/* ─ HELPERS ─ */
function showStatus(id,type,html){
  var el=document.getElementById(id);
  el.className='status '+type; el.innerHTML=html; el.style.display='block';
}
</script>
</body>
</html>